<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Product - Glitter.lk Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <div class="sidebar">
      <div class="sidebar-header">
        <h2>✨ Glitter.lk</h2>
        <p>Admin Panel</p>
      </div>
      <nav class="sidebar-nav">
        <a href="/admin/dashboard"><i class="fas fa-home"></i> Dashboard</a>
        <a href="/admin/products" class="active"><i class="fas fa-box"></i> All Products</a>
        <a href="/admin/products/add"><i class="fas fa-plus"></i> Add Product</a>
        <a href="/" target="_blank"><i class="fas fa-eye"></i> View Site</a>
        <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
      </nav>
    </div>

    <div class="main-content">
      <div class="content-header">
        <h1>Edit: <%= product.name %></h1>
        <a href="/admin/products" class="btn btn-secondary">← Back to Products</a>
      </div>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <div class="card">
        <!-- Current Images -->
        <% if (product.images && product.images.length > 0) { %>
          <div class="current-images">
            <h3>Current Images</h3>
            <div class="images-grid">
              <% product.images.forEach(function(img) { %>
                <div class="image-item">
                  <img src="<%= img %>" alt="">
                  <form action="/admin/products/delete-image/<%= product._id %>" method="POST">
                    <input type="hidden" name="imageUrl" value="<%= img %>">
                    <button type="submit" class="btn-remove-image" onclick="return confirm('Remove this image?')">✕</button>
                  </form>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>

        <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data" class="product-form">
          <div class="form-row">
            <div class="form-group">
              <label>Product Name *</label>
              <input type="text" name="name" required value="<%= product.name %>">
            </div>
            <div class="form-group">
              <label>Category *</label>
              <select name="category" required>
                <option value="necklaces" <%= product.category === 'necklaces' ? 'selected' : '' %>>Necklaces</option>
                <option value="earrings" <%= product.category === 'earrings' ? 'selected' : '' %>>Earrings</option>
                <option value="bracelets" <%= product.category === 'bracelets' ? 'selected' : '' %>>Bracelets</option>
                <option value="rings" <%= product.category === 'rings' ? 'selected' : '' %>>Rings</option>
                <option value="anklets" <%= product.category === 'anklets' ? 'selected' : '' %>>Anklets</option>
                <option value="hair-accessories" <%= product.category === 'hair-accessories' ? 'selected' : '' %>>Hair Accessories</option>
                <option value="sets" <%= product.category === 'sets' ? 'selected' : '' %>>Sets</option>
                <option value="other" <%= product.category === 'other' ? 'selected' : '' %>>Other</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label>Description *</label>
            <textarea name="description" rows="4" required><%= product.description %></textarea>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label>Price (Rs.) *</label>
              <input type="number" name="price" required min="0" step="0.01" value="<%= product.price %>">
            </div>
            <div class="form-group">
              <label>Sale Price (Rs.)</label>
              <input type="number" name="salePrice" min="0" step="0.01" value="<%= product.salePrice || '' %>">
            </div>
            <div class="form-group">
              <label>Quantity</label>
              <input type="number" name="quantity" min="0" value="<%= product.quantity %>">
            </div>
          </div>

          <div class="form-group">
            <label>Add More Images</label>
            <input type="file" name="images" multiple accept="image/*" class="file-input">
          </div>

          <div class="form-group">
            <label>Tags (comma separated)</label>
            <input type="text" name="tags" value="<%= product.tags ? product.tags.join(', ') : '' %>">
          </div>

          <div class="form-row checkboxes">
            <div class="form-group checkbox-group">
              <label>
                <input type="checkbox" name="inStock" <%= product.inStock ? 'checked' : '' %>>
                In Stock
              </label>
            </div>
            <div class="form-group checkbox-group">
              <label>
                <input type="checkbox" name="featured" <%= product.featured ? 'checked' : '' %>>
                Featured Product
              </label>
            </div>
          </div>

          <button type="submit" class="btn btn-primary btn-large">
            <i class="fas fa-save"></i> Update Product
          </button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>