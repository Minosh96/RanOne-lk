<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Product - Glitter.lk Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <div class="sidebar">
      <div class="sidebar-header">
        <h2>✨ Glitter.lk</h2>
        <p>Admin Panel</p>
      </div>
      <nav class="sidebar-nav">
        <a href="/admin/dashboard"><i class="fas fa-home"></i> Dashboard</a>
        <a href="/admin/products"><i class="fas fa-box"></i> All Products</a>
        <a href="/admin/products/add" class="active"><i class="fas fa-plus"></i> Add Product</a>
        <a href="/" target="_blank"><i class="fas fa-eye"></i> View Site</a>
        <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
      </nav>
    </div>

    <div class="main-content">
      <div class="content-header">
        <h1>Add New Product</h1>
        <a href="/admin/products" class="btn btn-secondary">← Back to Products</a>
      </div>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <div class="card">
        <form action="/admin/products/add" method="POST" enctype="multipart/form-data" class="product-form">
          <div class="form-row">
            <div class="form-group">
              <label>Product Name *</label>
              <input type="text" name="name" required placeholder="e.g., Gold Crystal Necklace">
            </div>
            <div class="form-group">
              <label>Category *</label>
              <select name="category" required>
                <option value="">Select Category</option>
                <option value="necklaces">Necklaces</option>
                <option value="earrings">Earrings</option>
                <option value="bracelets">Bracelets</option>
                <option value="rings">Rings</option>
                <option value="anklets">Anklets</option>
                <option value="hair-accessories">Hair Accessories</option>
                <option value="sets">Sets</option>
                <option value="other">Other</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label>Description *</label>
            <textarea name="description" rows="4" required placeholder="Describe the product..."></textarea>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label>Price (Rs.) *</label>
              <input type="number" name="price" required min="0" step="0.01" placeholder="1500">
            </div>
            <div class="form-group">
              <label>Sale Price (Rs.) - Leave empty if no sale</label>
              <input type="number" name="salePrice" min="0" step="0.01" placeholder="1200">
            </div>
            <div class="form-group">
              <label>Quantity</label>
              <input type="number" name="quantity" min="0" value="1" placeholder="10">
            </div>
          </div>

          <div class="form-group">
            <label>Product Images (up to 5)</label>
            <input type="file" name="images" multiple accept="image/*" class="file-input">
            <small>Accepted: JPG, PNG, GIF, WebP. Max 5MB each.</small>
          </div>

          <div class="form-group">
            <label>Tags (comma separated)</label>
            <input type="text" name="tags" placeholder="e.g., gold, crystal, wedding, trendy">
          </div>

          <div class="form-row checkboxes">
            <div class="form-group checkbox-group">
              <label>
                <input type="checkbox" name="inStock" checked>
                In Stock
              </label>
            </div>
            <div class="form-group checkbox-group">
              <label>
                <input type="checkbox" name="featured">
                Featured Product (shows on homepage)
              </label>
            </div>
          </div>

          <button type="submit" class="btn btn-primary btn-large">
            <i class="fas fa-plus"></i> Add Product
          </button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>