<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shop - RanOne</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- NAVIGATION -->
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="logo">
        <span class="logo-icon">✨</span>
        <span class="logo-text">RanOne<span class="logo-dot"></span></span>
      </a>
      <div class="nav-links" id="navLinks">
        <a href="/">Home</a>
        <a href="/shop" class="active">Shop</a>
        <a href="/shop?category=necklaces">Necklaces</a>
        <a href="/shop?category=earrings">Earrings</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <button class="mobile-menu-btn" onclick="toggleMenu()">
        <i class="fas fa-bars"></i>
      </button>
    </div>
  </nav>

  <div class="page-header">
    <h1>✨ Our Collection</h1>
    <p>Find your perfect sparkle</p>
  </div>

  <div class="shop-container">
    <!-- FILTERS -->
    <div class="shop-filters">
      <form method="GET" action="/shop" class="filter-form">
        <div class="filter-group">
          <label>Search</label>
          <input type="text" name="search" placeholder="Search ornaments..." value="<%= searchTerm %>" class="filter-input">
        </div>
        <div class="filter-group">
          <label>Category</label>
          <select name="category" class="filter-select">
            <option value="all" <%= currentCategory === 'all' ? 'selected' : '' %>>All Categories</option>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat %>" <%= currentCategory === cat ? 'selected' : '' %>>
                <%= cat.charAt(0).toUpperCase() + cat.slice(1).replace('-', ' ') %>
              </option>
            <% }); %>
          </select>
        </div>
        <div class="filter-group">
          <label>Sort By</label>
          <select name="sort" class="filter-select">
            <option value="newest" <%= currentSort === 'newest' ? 'selected' : '' %>>Newest First</option>
            <option value="price-low" <%= currentSort === 'price-low' ? 'selected' : '' %>>Price: Low to High</option>
            <option value="price-high" <%= currentSort === 'price-high' ? 'selected' : '' %>>Price: High to Low</option>
            <option value="name" <%= currentSort === 'name' ? 'selected' : '' %>>Name A-Z</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-filter">Apply Filters</button>
      </form>
    </div>

    <!-- PRODUCTS -->
    <div class="shop-results">
      <p class="results-count"><%= products.length %> products found</p>
      <% if (products.length > 0) { %>
        <div class="products-grid">
          <% products.forEach(function(product) { %>
            <div class="product-card">
              <a href="/product/<%= product._id %>">
                <div class="product-image">
                  <% if (product.images && product.images.length > 0) { %>
                    <img src="<%= product.images[0] %>" alt="<%= product.name %>">
                  <% } else { %>
                    <div class="no-image">✨</div>
                  <% } %>
                  <% if (product.salePrice) { %>
                    <span class="sale-badge">SALE</span>
                  <% } %>
                </div>
                <div class="product-info">
                  <h3 class="product-name"><%= product.name %></h3>
                  <p class="product-category"><%= product.category %></p>
                  <div class="product-price">
                    <% if (product.salePrice) { %>
                      <span class="original-price">Rs. <%= product.price.toLocaleString() %></span>
                      <span class="sale-price">Rs. <%= product.salePrice.toLocaleString() %></span>
                    <% } else { %>
                      <span class="current-price">Rs. <%= product.price.toLocaleString() %></span>
                    <% } %>
                  </div>
                </div>
              </a>
              <a href="https://wa.me/94773690499?text=Hi! I'm interested in <%= encodeURIComponent(product.name) %>" 
                 class="btn btn-whatsapp" target="_blank">
                <i class="fab fa-whatsapp"></i> Order via WhatsApp
              </a>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="no-products">
          <h3>No products found 😢</h3>
          <p>Try a different search or category</p>
          <a href="/shop" class="btn btn-primary">View All Products</a>
        </div>
      <% } %>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-bottom">
      <p>2026 RanOne - Melow's All rights</p>
    </div>
  </footer>

  <script>
    function toggleMenu() {
      document.getElementById('navLinks').classList.toggle('active');
    }
  </script>
</body>
</html>